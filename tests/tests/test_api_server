# ── Schema validation tests ───────────────────────────────────────────────────

class TestInputSchema:
    """Test that Pydantic validation catches bad inputs correctly."""

    def test_invalid_contract_type_rejected(self, client):
        bad = {**VALID_PAYLOAD, "contract_type": "Weekly"}
        resp = client.post("/predict", json=bad)
        assert resp.status_code == 422, "Invalid contract_type should return 422"

    def test_invalid_payment_method_rejected(self, client):
        bad = {**VALID_PAYLOAD, "payment_method": "Crypto"}
        resp = client.post("/predict", json=bad)
        assert resp.status_code == 422

    def test_negative_tenure_rejected(self, client):
        bad = {**VALID_PAYLOAD, "tenure": -5}
        resp = client.post("/predict", json=bad)
        assert resp.status_code == 422

    def test_invalid_yes_no_field_rejected(self, client):
        bad = {**VALID_PAYLOAD, "tech_support": "Maybe"}
        resp = client.post("/predict", json=bad)
        assert resp.status_code == 422

    def test_missing_required_field_rejected(self, client):
        bad = {k: v for k, v in VALID_PAYLOAD.items() if k != "tenure"}
        resp = client.post("/predict", json=bad)
        assert resp.status_code == 422

    def test_all_valid_fields_accepted(self, client):
        """A well-formed request should get past schema validation (may 503 if no model)."""
        resp = client.post("/predict", json=VALID_PAYLOAD)
        # 200 if model loaded, 503 if not — both are acceptable here
        assert resp.status_code in (200, 503), f"Unexpected status {resp.status_code}"


# ── Health endpoint ───────────────────────────────────────────────────────────

class TestHealthEndpoint:
    def test_health_returns_200(self, client):
        resp = client.get("/health")
        assert resp.status_code == 200

    def test_health_has_required_fields(self, client):
        data = client.get("/health").json()
        required = ["status", "model_loaded", "window_size", "predictions_served",
                    "cpu_pct", "memory_pct", "uptime_seconds"]
        for field in required:
            assert field in data, f"Missing field: {field}"

    def test_health_status_is_valid(self, client):
        data = client.get("/health").json()
        assert data["status"] in ("ok", "degraded")

    def test_uptime_is_positive(self, client):
        data = client.get("/health").json()
        assert data["uptime_seconds"] >= 0


