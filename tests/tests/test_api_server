# ── Fixtures ──────────────────────────────────────────────────────────────────

@pytest.fixture(scope="module")
def client():
    """
    Create a TestClient with the server in a model-not-loaded state.
    This tests the schema validation and routing logic without needing
    a trained model on disk.
    """
