# ── Window reset endpoint ─────────────────────────────────────────────────────

class TestWindowResetEndpoint:
    def test_reset_returns_ok(self, client):
        resp = client.delete("/window/reset")
        assert resp.status_code == 200
        data = resp.json()
        assert data["status"] == "ok"

    def test_window_empty_after_reset(self, client):
        client.delete("/window/reset")
        health = client.get("/health").json()
        assert health["window_size"] == 0
        assert health["predictions_served"] == 0


# ── Batch predict schema ──────────────────────────────────────────────────────

class TestBatchPredictSchema:
    def test_empty_batch_rejected(self, client):
        resp = client.post("/predict/batch", json={"records": []})
        assert resp.status_code == 422

    def test_invalid_record_in_batch_rejected(self, client):
        bad_record = {**VALID_PAYLOAD, "contract_type": "Invalid"}
        resp = client.post("/predict/batch", json={"records": [bad_record]})
        assert resp.status_code == 422

    def test_valid_batch_reaches_model(self, client):
        payload = {"records": [VALID_PAYLOAD, HIGH_RISK_PAYLOAD], "threshold": 0.5}
        resp = client.post("/predict/batch", json=payload)
        assert resp.status_code in (200, 503)


# ── Risk level logic ──────────────────────────────────────────────────────────

class TestRiskLevelLogic:
    """Test the risk level helper directly — no model needed."""
    def test_risk_level_thresholds(self):
        from src.api.server import _risk_level
        assert _risk_level(0.10) == "low"
        assert _risk_level(0.39) == "low"
        assert _risk_level(0.40) == "medium"
        assert _risk_level(0.69) == "medium"
        assert _risk_level(0.70) == "high"
        assert _risk_level(0.99) == "high"


# ── CustomerFeatures model ────────────────────────────────────────────────────

class TestCustomerFeaturesModel:
    def test_to_dataframe_has_correct_columns(self):
        from src.api.server import CustomerFeatures
        cf = CustomerFeatures(**VALID_PAYLOAD)
        df = cf.to_dataframe()
        from src.config import model_config
        for col in model_config.numerical_features + model_config.categorical_features:
            assert col in df.columns, f"Missing column: {col}"

    def test_to_dataframe_has_one_row(self):
        from src.api.server import CustomerFeatures
        cf = CustomerFeatures(**VALID_PAYLOAD)
        assert len(cf.to_dataframe()) == 1
