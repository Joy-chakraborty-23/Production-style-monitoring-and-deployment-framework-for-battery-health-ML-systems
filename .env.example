# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# Slack webhook URL for alert notifications
# Create at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email alert config (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
ALERT_EMAIL_SENDER=your_alerts@gmail.com
ALERT_EMAIL_PASSWORD=your_app_password

# Dashboard settings
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8050
DASHBOARD_DEBUG=false

# MLflow settings (default uses local filesystem)
MLFLOW_TRACKING_URI=./mlruns

# Alert cooldown (minutes) — prevents alert storms
ALERT_COOLDOWN_MINUTES=30
