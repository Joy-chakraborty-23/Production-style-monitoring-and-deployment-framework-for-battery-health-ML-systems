# ── Startup / shutdown ────────────────────────────────────────────────────────

@app.on_event("startup")
async def startup_event():
    """Load model, reference data, and initialise monitoring components."""
    logger.info("FastAPI server starting — loading components...")

    # Load model pipeline
    try:
        state.pipeline = load_model()
        state.model_version = "churn_xgboost_v1"
        logger.info(f"Model loaded: {MODELS_DIR / 'churn_pipeline.joblib'}")
    except FileNotFoundError:
        logger.warning(
            "No trained model found. Run 'python -m src.models.train_model' first. "
            "Server will start but /predict will return 503 until model is loaded."
        )

    # Load reference data for drift detection
    if REFERENCE_DATA_PATH.exists():
        state.reference_df = pd.read_csv(REFERENCE_DATA_PATH)
        logger.info(f"Reference data loaded: {len(state.reference_df)} rows")

        if state.pipeline is not None:
            state.drift_detector = DriftDetector(state.reference_df)
            logger.info("DriftDetector initialised against reference distribution")

            # Compute baseline AUC on reference data for ROI calculator
            try:
                from sklearn.metrics import roc_auc_score
                _ref_X = state.reference_df[
                    model_config.numerical_features + model_config.categorical_features
                ].copy()
                _ref_y = state.reference_df["churn"]
                _baseline_auc = float(roc_auc_score(
                    _ref_y, state.pipeline.predict_proba(_ref_X)[:, 1]
                ))
            except Exception:
                _baseline_auc = 0.87

            state.roi_calculator = ROICalculator(
                monthly_customers      = roi_config.monthly_customers,
                avg_ltv                = roi_config.avg_customer_ltv,
                outreach_cost_per_call = roi_config.outreach_cost_per_call,
                baseline_auc           = _baseline_auc,
                true_churn_rate        = roi_config.true_churn_rate,
                outreach_coverage      = roi_config.outreach_coverage,
                recall_sensitivity     = roi_config.recall_sensitivity,
            )
            logger.info(f"ROICalculator initialised — baseline AUC: {_baseline_auc:.4f}")
    else:
        logger.warning(
            f"Reference data not found at {REFERENCE_DATA_PATH}. "
            "Drift detection will be skipped. Run 'python -m src.data.data_generator' first."
        )

    state.alert_manager = AlertManager()
    logger.info("AlertManager initialised")
    logger.info("Server startup complete")


# ════════════════════════════════════════════════════════════════════════════
# Helper functions
# ════════════════════════════════════════════════════════════════════════════

def _require_model():
    """Raise 503 if model is not loaded."""
    if not state.is_ready():
        raise HTTPException(
            status_code=503,
            detail="Model not loaded. Run 'python -m src.models.train_model' then restart."
        )


def _risk_level(prob: float) -> str:
    if prob >= 0.70:
        return "high"
    if prob >= 0.40:
        return "medium"
    return "low"


def _score_single(features: CustomerFeatures, threshold: float) -> tuple[float, float]:
    """
    Run inference on one record.

    Returns:
        (churn_probability, latency_ms)
    """
    t0 = time.perf_counter()
    X  = features.to_dataframe()
    prob = float(state.pipeline.predict_proba(X)[0, 1])
    latency_ms = (time.perf_counter() - t0) * 1_000
    return prob, latency_ms


def _log_to_window(features: CustomerFeatures, prob: float) -> None:
    """Append a prediction record to the sliding window."""
    record = features.model_dump()
    record["prediction_score"] = prob
    record["timestamp"]        = time.time()
    state.add_to_window(record)


# ════════════════════════════════════════════════════════════════════════════
# Background drift check  (runs after every DRIFT_CHECK_EVERY predictions)
# ════════════════════════════════════════════════════════════════════════════

def _run_drift_check() -> None:
    """
    Pull the current window, run DriftDetector, compute ROI impact,
    persist a snapshot, and fire alerts if needed.

    Runs in a background thread — never blocks the prediction response.
    """
    if state.drift_detector is None or state.roi_calculator is None:
        return

    window_df = state.get_window_snapshot()
    if len(window_df) < 100:
        logger.debug(f"Drift check skipped — window too small ({len(window_df)} records)")
        return

    logger.info(f"Background drift check — window size: {len(window_df)}")

    try:
        # Use a synthetic batch_id based on prediction count
        synthetic_batch_id = state.predictions_served // DRIFT_CHECK_EVERY

        # Prediction drift: check the score distribution in the window
        ref_X = state.reference_df[
            model_config.numerical_features + model_config.categorical_features
        ].copy()
        ref_preds   = state.pipeline.predict_proba(ref_X)[:, 1]
        window_preds = window_df["prediction_score"].values

        drift_report = state.drift_detector.detect(
            window_df,
            batch_id=synthetic_batch_id,
            ref_predictions=ref_preds,
            prod_predictions=window_preds,
        )

        # Estimate current AUC from prediction score distribution shift
        # (We don't have true labels — use PSI on scores as a proxy)
        pred_psi     = drift_report.prediction_drift.score if drift_report.prediction_drift else 0.0
        estimated_auc_drop = min(pred_psi * 0.4, 0.15)
        estimated_auc      = max(state.roi_calculator.baseline_auc - estimated_auc_drop, 0.5)

        roi_result = state.roi_calculator.compute_monthly_loss(estimated_auc)

        # Build log entry
        log_entry = {
            "timestamp":           datetime.now().isoformat(),
            "predictions_at_check": state.predictions_served,
            "window_size":         len(window_df),
            "drift_severity":      drift_report.overall_severity,
            "drift_score":         round(drift_report.overall_drift_score, 6),
            "n_drifted_features":  drift_report.n_drifted_features,
            "drifted_features":    drift_report.drifted_features,
            "estimated_auc":       round(estimated_auc, 4),
            "roi_monthly_loss":    roi_result.total_monthly_loss,
            "roi_status":          roi_result.status,
            "roi_headline":        roi_result.headline,
        }

        state.drift_log.append(log_entry)
        state.last_drift_check    = log_entry["timestamp"]
        state.last_drift_severity = drift_report.overall_severity

        # Persist drift log
        SERVER_LOG_PATH.parent.mkdir(parents=True, exist_ok=True)
        with open(SERVER_LOG_PATH, "w") as f:
            json.dump(state.drift_log[-50:], f, indent=2)   # keep last 50 entries

        # Fire alert if needed
        if drift_report.overall_severity in ("warning", "critical") and state.alert_manager:
            fire_drift_alert(
                state.alert_manager,
                batch_id=synthetic_batch_id,
                severity=drift_report.overall_severity,
                drifted_features=drift_report.drifted_features,
                drift_score=drift_report.overall_drift_score,
            )

        logger.info(
            f"Drift check complete — severity={drift_report.overall_severity} | "
            f"est_auc={estimated_auc:.4f} | roi={roi_result.headline[:60]}"
        )

    except Exception as exc:
        logger.error(f"Background drift check failed: {exc}")


