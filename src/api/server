class CustomerFeatures(BaseModel):
    """Input schema — matches the 16 features the pipeline was trained on."""
    tenure:                   float = Field(..., ge=0,   le=100,  description="Months as a customer")
    monthly_charges:          float = Field(..., ge=0,   le=500,  description="Monthly bill amount")
    total_charges:            float = Field(..., ge=0,             description="Total billed to date")
    num_products:             int   = Field(..., ge=1,   le=10,   description="Number of active products")
    num_support_calls:        int   = Field(..., ge=0,   le=50,   description="Support calls in last 90 days")
    avg_call_duration:        float = Field(..., ge=0,             description="Average support call duration (min)")
    days_since_last_login:    int   = Field(..., ge=0,             description="Days since last app/web login")
    data_usage_gb:            float = Field(..., ge=0,             description="Monthly data usage in GB")
    billing_amount_variance:  float = Field(..., ge=0,             description="Variance in billing amount")
    customer_lifetime_value:  float = Field(..., ge=0,             description="Estimated customer LTV")
    contract_type:            str   = Field(...,                   description="Contract type")
    payment_method:           str   = Field(...,                   description="Payment method")
    internet_service:         str   = Field(...,                   description="Internet service type")
    tech_support:             str   = Field(...,                   description="Has tech support add-on")
    online_security:          str   = Field(...,                   description="Has online security add-on")
    paperless_billing:        str   = Field(...,                   description="Uses paperless billing")

    @field_validator("contract_type")
    @classmethod
    def validate_contract(cls, v):
        if v not in CONTRACT_TYPES:
            raise ValueError(f"contract_type must be one of {CONTRACT_TYPES}")
        return v

    @field_validator("payment_method")
    @classmethod
    def validate_payment(cls, v):
        if v not in PAYMENT_METHODS:
            raise ValueError(f"payment_method must be one of {PAYMENT_METHODS}")
        return v

    @field_validator("internet_service")
    @classmethod
    def validate_internet(cls, v):
        if v not in INTERNET_SERVICES:
            raise ValueError(f"internet_service must be one of {INTERNET_SERVICES}")
        return v

    @field_validator("tech_support", "online_security", "paperless_billing")
    @classmethod
    def validate_yes_no(cls, v):
        if v not in YES_NO:
            raise ValueError(f"Value must be one of {YES_NO}")
        return v

    def to_dataframe(self) -> pd.DataFrame:
        return pd.DataFrame([self.model_dump()])


class BatchPredictRequest(BaseModel):
    records: List[CustomerFeatures] = Field(..., min_length=1, max_length=500)
    threshold: float = Field(DEFAULT_THRESHOLD, ge=0.01, le=0.99)


class PredictResponse(BaseModel):
    churn_probability: float
    churn_prediction:  bool
    risk_level:        str   # "low" | "medium" | "high"
    threshold_used:    float
    latency_ms:        float
    request_id:        str
    model_version:     str


class BatchPredictResponse(BaseModel):
    predictions:  List[PredictResponse]
    n_records:    int
    n_high_risk:  int
    latency_ms:   float


class HealthResponse(BaseModel):
    status:          str
    model_loaded:    bool
    window_size:     int
    predictions_served: int
    last_drift_check:   Optional[str]
    last_drift_severity: str
    cpu_pct:         float
    memory_pct:      float
    uptime_seconds:  float


# ════════════════════════════════════════════════════════════════════════════
# Server State  (module-level singletons, initialised on startup)
# ════════════════════════════════════════════════════════════════════════════

class ServerState:
    """Thread-safe server state container."""

    def __init__(self):
        self._lock               = threading.Lock()
        self.pipeline            = None
        self.drift_detector      = None
        self.roi_calculator      = None
        self.alert_manager       = None
        self.reference_df        = None
        self.model_version       = "unknown"

        # Sliding window: stores dicts of {features..., prediction, timestamp}
        self._window: deque      = deque(maxlen=WINDOW_SIZE)

        # Counters
        self.predictions_served  = 0
        self.last_drift_check    = None
        self.last_drift_severity = "none"
        self.start_time          = time.time()

        # In-memory drift log (also persisted to disk)
        self.drift_log: list     = []

    def add_to_window(self, record: dict) -> None:
        with self._lock:
            self._window.append(record)
            self.predictions_served += 1

    def get_window_snapshot(self) -> pd.DataFrame:
        with self._lock:
            if not self._window:
                return pd.DataFrame()
            return pd.DataFrame(list(self._window))

    @property
    def window_size(self) -> int:
        with self._lock:
            return len(self._window)

    def is_ready(self) -> bool:
        return self.pipeline is not None


state = ServerState()


