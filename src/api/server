# Endpoints
# ════════════════════════════════════════════════════════════════════════════

@app.post("/predict", response_model=PredictResponse, summary="Score a single customer record")
async def predict(
    features: CustomerFeatures,
    background_tasks: BackgroundTasks,
    threshold: float = DEFAULT_THRESHOLD,
):
    """
    Predict churn probability for a single customer.

    Returns the probability score, binary prediction at the chosen threshold,
    risk level, and inference latency in milliseconds.
    """
    _require_model()

    prob, latency_ms = _score_single(features, threshold)
    _log_to_window(features, prob)

    # Trigger background drift check every DRIFT_CHECK_EVERY predictions
    if state.predictions_served % DRIFT_CHECK_EVERY == 0 and state.predictions_served > 0:
        background_tasks.add_task(_run_drift_check)

    return PredictResponse(
        churn_probability = round(prob, 4),
        churn_prediction  = prob >= threshold,
        risk_level        = _risk_level(prob),
        threshold_used    = threshold,
        latency_ms        = round(latency_ms, 3),
        request_id        = f"req_{int(time.time()*1000)}_{state.predictions_served}",
        model_version     = state.model_version,
    )


@app.post("/predict/batch", response_model=BatchPredictResponse, summary="Score multiple records")
async def predict_batch(
    request: BatchPredictRequest,
    background_tasks: BackgroundTasks,
):
    """
    Score a list of customer records in a single request (max 500).

    More efficient than calling /predict in a loop when you have many records.
    """
    _require_model()

    t0 = time.perf_counter()
    responses = []

    for rec in request.records:
        prob, lat = _score_single(rec, request.threshold)
        _log_to_window(rec, prob)
        responses.append(PredictResponse(
            churn_probability = round(prob, 4),
            churn_prediction  = prob >= request.threshold,
            risk_level        = _risk_level(prob),
            threshold_used    = request.threshold,
            latency_ms        = round(lat, 3),
            request_id        = f"batch_{int(time.time()*1000)}_{state.predictions_served}",
            model_version     = state.model_version,
        ))

    total_ms = (time.perf_counter() - t0) * 1_000
    n_high   = sum(1 for r in responses if r.risk_level == "high")

    if state.predictions_served % DRIFT_CHECK_EVERY == 0 and state.predictions_served > 0:
        background_tasks.add_task(_run_drift_check)

    return BatchPredictResponse(
        predictions  = responses,
        n_records    = len(responses),
        n_high_risk  = n_high,
        latency_ms   = round(total_ms, 3),
    )


@app.get("/health", response_model=HealthResponse, summary="Server liveness + model status")
async def health():
    """
    Returns server health, model status, window size, and system resource usage.
    Use this as a readiness/liveness probe in Kubernetes or Docker.
    """
    return HealthResponse(
        status               = "ok" if state.is_ready() else "degraded",
        model_loaded         = state.is_ready(),
        window_size          = state.window_size,
        predictions_served   = state.predictions_served,
        last_drift_check     = state.last_drift_check,
        last_drift_severity  = state.last_drift_severity,
        cpu_pct              = round(psutil.cpu_percent(interval=None), 1),
        memory_pct           = round(psutil.virtual_memory().percent, 1),
        uptime_seconds       = round(time.time() - state.start_time, 1),
    )


@app.get("/metrics", summary="Current drift + ROI snapshot from the sliding window")
async def metrics():
    """
    Returns the most recent drift check result and ROI impact estimate.
    If no drift check has run yet (fewer than 100 records in window),
    returns a placeholder with window progress.
    """
    if not state.drift_log:
        return JSONResponse({
            "status":    "warming_up",
            "message":   f"Collecting window data — {state.window_size}/{DRIFT_CHECK_EVERY} predictions until first drift check",
            "window_size": state.window_size,
            "predictions_served": state.predictions_served,
        })

    latest = state.drift_log[-1]
    return JSONResponse({
        "status":        "active",
        "latest_check":  latest,
        "total_checks":  len(state.drift_log),
        "predictions_served": state.predictions_served,
        "window_size":   state.window_size,
    })


@app.get("/window/stats", summary="Feature distribution statistics for the current window")
async def window_stats():
    """
    Returns mean, std, min, max, p25, p50, p75 for every numerical feature
    currently in the sliding window. Useful for manual drift inspection.
    """
    window_df = state.get_window_snapshot()
    if window_df.empty:
        return JSONResponse({"status": "empty", "message": "No predictions in window yet"})

    stats = {}
    for feat in model_config.numerical_features:
        if feat in window_df.columns:
            col = window_df[feat].dropna()
            stats[feat] = {
                "mean": round(float(col.mean()), 4),
                "std":  round(float(col.std()), 4),
                "min":  round(float(col.min()), 4),
                "p25":  round(float(col.quantile(0.25)), 4),
                "p50":  round(float(col.quantile(0.50)), 4),
                "p75":  round(float(col.quantile(0.75)), 4),
                "max":  round(float(col.max()), 4),
            }

    cat_stats = {}
    for feat in model_config.categorical_features:
        if feat in window_df.columns:
            counts = window_df[feat].value_counts(normalize=True).round(4).to_dict()
            cat_stats[feat] = counts

    avg_pred = round(float(window_df["prediction_score"].mean()), 4) if "prediction_score" in window_df.columns else None
    high_risk_pct = round(float((window_df["prediction_score"] >= 0.70).mean()) * 100, 1) if "prediction_score" in window_df.columns else None

    return JSONResponse({
        "window_size":        len(window_df),
        "predictions_served": state.predictions_served,
        "avg_churn_prob":     avg_pred,
        "high_risk_pct":      high_risk_pct,
        "numerical_stats":    stats,
        "categorical_stats":  cat_stats,
    })


@app.delete("/window/reset", summary="Clear the feature sliding window (testing only)")
async def reset_window():
    """Clears the prediction window. Use during testing to start fresh."""
    with state._lock:
        state._window.clear()
        state.predictions_served = 0
        state.drift_log.clear()
        state.last_drift_check = None
        state.last_drift_severity = "none"
    logger.info("Sliding window reset")
    return JSONResponse({"status": "ok", "message": "Window cleared"})
