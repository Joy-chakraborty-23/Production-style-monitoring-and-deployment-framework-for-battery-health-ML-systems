# ── Data loading ─────────────────────────────────────────────────────────────

def load_data() -> dict:
    data = {}
    try:
        p = MODELS_DIR / "monitoring_summary.json"
        data["summary"] = pd.read_json(p) if p.exists() else pd.DataFrame()
    except Exception:
        data["summary"] = pd.DataFrame()

    try:
        p = MODELS_DIR / "performance_history.json"
        data["performance"] = pd.read_json(p) if p.exists() else pd.DataFrame()
    except Exception:
        data["performance"] = pd.DataFrame()

    try:
        p = MODELS_DIR / "drift_details.json"
        data["drift"] = pd.read_json(p) if p.exists() else pd.DataFrame()
    except Exception:
        data["drift"] = pd.DataFrame()

    try:
        p = MODELS_DIR / "alert_log.json"
        if p.exists():
            with open(p) as f:
                data["alerts"] = pd.DataFrame(json.load(f))
        else:
            data["alerts"] = pd.DataFrame()
    except Exception:
        data["alerts"] = pd.DataFrame()

    try:
        p = MODELS_DIR / "retrain_log.json"
        if p.exists():
            with open(p) as f:
                data["retrain"] = pd.DataFrame(json.load(f))
        else:
            data["retrain"] = pd.DataFrame()
    except Exception:
        data["retrain"] = pd.DataFrame()

    try:
        p = MODELS_DIR / "fleet_health.json"
        data["fleet"] = pd.read_json(p) if p.exists() else pd.DataFrame()
    except Exception:
        data["fleet"] = pd.DataFrame()

    return data


# ── Chart builders ─────────────────────────────────────────────────────────

def build_auc_trend_chart(df: pd.DataFrame) -> go.Figure:
    fig = go.Figure()

    if df.empty:
        return fig

    # AUC line
    fig.add_trace(go.Scatter(
        x=df["batch_id"], y=df["auc_roc"],
        mode="lines+markers", name="AUC-ROC",
        line=dict(color=COLORS["blue"], width=2.5),
        marker=dict(size=7, color=[
            COLORS["critical"] if v < 0.70 else
            COLORS["warning"]  if v < 0.80 else
            COLORS["none"] for v in df["auc_roc"]
        ])
    ))

    # F1 line
    fig.add_trace(go.Scatter(
        x=df["batch_id"], y=df["f1"],
        mode="lines+markers", name="F1 Score",
        line=dict(color=COLORS["teal"], width=2, dash="dot"),
        marker=dict(size=5),
    ))

    # Threshold lines
    fig.add_hline(y=0.80, line_dash="dash", line_color=COLORS["warning"],
                  annotation_text="Warning (0.80)", annotation_position="right")
    fig.add_hline(y=0.70, line_dash="dash", line_color=COLORS["critical"],
                  annotation_text="Critical (0.70)", annotation_position="right")

    # Shade retrain events
    if "retrain_triggered" in df.columns:
        for _, row in df[df["retrain_triggered"]].iterrows():
            fig.add_vline(x=row["batch_id"], line_dash="dot",
                          line_color=COLORS["purple"], opacity=0.6,
                          annotation_text="Retrain", annotation_position="top")

    fig.update_layout(
        title="Model Performance Over Production Batches",
        xaxis_title="Batch ID", yaxis_title="Score",
        yaxis=dict(range=[0, 1.05]),
        plot_bgcolor=COLORS["card"], paper_bgcolor=COLORS["card"],
        font=dict(color=COLORS["text"]),
        legend=dict(bgcolor=COLORS["card"], bordercolor=COLORS["border"]),
        margin=dict(l=40, r=40, t=40, b=40),
        hovermode="x unified",
    )
    return fig


def build_drift_timeline_chart(df: pd.DataFrame) -> go.Figure:
    if df.empty:
        return go.Figure()

    severity_map = {"none": 0, "warning": 1, "critical": 2}
    color_map    = {0: COLORS["none"], 1: COLORS["warning"], 2: COLORS["critical"]}

    fig = go.Figure()
    if "drift_score" in df.columns:
        fig.add_trace(go.Scatter(
            x=df["batch_id"], y=df["drift_score"],
            fill="tozeroy", fillcolor="rgba(55,138,221,0.15)",
            line=dict(color=COLORS["blue"], width=2),
            name="Overall Drift Score",
            mode="lines+markers",
            marker=dict(size=8, color=[
                color_map.get(severity_map.get(s, 0), COLORS["none"])
                for s in df.get("drift_severity", ["none"] * len(df))
            ])
        ))

        fig.add_hline(y=0.10, line_dash="dash", line_color=COLORS["warning"],
                      annotation_text="Warning (PSI 0.10)")
        fig.add_hline(y=0.20, line_dash="dash", line_color=COLORS["critical"],
                      annotation_text="Critical (PSI 0.20)")

    fig.update_layout(
        title="Overall Drift Score Timeline",
        xaxis_title="Batch ID", yaxis_title="Drift Score (PSI)",
        plot_bgcolor=COLORS["card"], paper_bgcolor=COLORS["card"],
        font=dict(color=COLORS["text"]),
        margin=dict(l=40, r=40, t=40, b=40),
    )
    return fig


def build_psi_heatmap(drift_df: pd.DataFrame) -> go.Figure:
    if drift_df.empty:
        return go.Figure()

    num_features = [
        "tenure", "monthly_charges", "total_charges", "num_products",
        "num_support_calls", "avg_call_duration", "days_since_last_login",
        "data_usage_gb", "billing_amount_variance", "customer_lifetime_value"
    ]
    available = [f for f in num_features if f in drift_df["feature"].values]
    if not available:
        return go.Figure()

    filtered = drift_df[drift_df["feature"].isin(available)]
    pivot = filtered.pivot_table(
        index="feature", columns="batch_id", values="score", aggfunc="mean"
    ).fillna(0)

    fig = go.Figure(data=go.Heatmap(
        z=pivot.values,
        x=[f"Batch {c}" for c in pivot.columns],
        y=pivot.index.tolist(),
        colorscale=[
            [0.0,  "#1a1e2e"],
            [0.05, "#27ae60"],
            [0.10, "#f39c12"],
            [0.20, "#e74c3c"],
            [1.0,  "#8b0000"],
        ],
        colorbar=dict(title="PSI Score"),
        hovertemplate="Feature: %{y}<br>%{x}<br>PSI: %{z:.4f}<extra></extra>",
    ))

    fig.update_layout(
        title="Feature Drift Heatmap (PSI by Batch)",
        plot_bgcolor=COLORS["card"], paper_bgcolor=COLORS["card"],
        font=dict(color=COLORS["text"]),
        margin=dict(l=140, r=40, t=40, b=60),
        xaxis=dict(tickangle=-30),
    )
    return fig


def build_precision_recall_chart(df: pd.DataFrame) -> go.Figure:
    if df.empty:
        return go.Figure()

    fig = make_subplots(specs=[[{"secondary_y": True}]])
    fig.add_trace(go.Scatter(
        x=df["batch_id"], y=df["precision"],
        mode="lines+markers", name="Precision",
        line=dict(color=COLORS["teal"]),
    ))
    fig.add_trace(go.Scatter(
        x=df["batch_id"], y=df["recall"],
        mode="lines+markers", name="Recall",
        line=dict(color=COLORS["amber"]),
    ))
    fig.add_trace(go.Bar(
        x=df["batch_id"], y=df["churn_rate_true"],
        name="True Churn Rate", opacity=0.3,
        marker_color=COLORS["purple"],
    ), secondary_y=True)

    fig.update_layout(
        title="Precision, Recall & Churn Rate",
        plot_bgcolor=COLORS["card"], paper_bgcolor=COLORS["card"],
        font=dict(color=COLORS["text"]),
        margin=dict(l=40, r=60, t=40, b=40),
        legend=dict(bgcolor=COLORS["card"]),
    )
    fig.update_yaxes(title_text="Score", range=[0, 1.05], secondary_y=False)
    fig.update_yaxes(title_text="Churn Rate", range=[0, 0.5], secondary_y=True)
    return fig


# ── ROI Chart builders ────────────────────────────────────────────────────────

def build_roi_loss_chart(df: pd.DataFrame) -> go.Figure:
    """Stacked bar: monthly revenue at risk + wasted outreach per batch."""
    if df.empty or "roi_revenue_at_risk" not in df.columns:
        return go.Figure()

    fig = go.Figure()
    fig.add_trace(go.Bar(
        x=df["batch_id"], y=df["roi_revenue_at_risk"],
        name="Revenue at risk", marker_color="#E24B4A", opacity=0.85,
    ))
    fig.add_trace(go.Bar(
        x=df["batch_id"], y=df["roi_wasted_outreach"],
        name="Wasted outreach", marker_color="#EF9F27", opacity=0.85,
    ))
    fig.update_layout(
        barmode="stack",
        title="Estimated Monthly Business Loss per Batch (₹)",
        xaxis_title="Batch ID", yaxis_title="Loss (₹)",
        plot_bgcolor=COLORS["card"], paper_bgcolor=COLORS["card"],
        font=dict(color=COLORS["text"]),
        legend=dict(bgcolor=COLORS["card"]),
        margin=dict(l=60, r=40, t=40, b=40),
    )
    return fig


def build_roi_churner_chart(df: pd.DataFrame) -> go.Figure:
    """Line chart: missed churners per batch overlaid with AUC."""
    if df.empty or "roi_missed_churners" not in df.columns:
        return go.Figure()

    fig = make_subplots(specs=[[{"secondary_y": True}]])
    fig.add_trace(go.Scatter(
        x=df["batch_id"], y=df["roi_missed_churners"],
        name="Missed churners/mo", mode="lines+markers",
        line=dict(color="#E24B4A", width=2.5),
        marker=dict(size=7),
    ), secondary_y=False)
    fig.add_trace(go.Scatter(
        x=df["batch_id"], y=df["auc_roc"],
        name="AUC-ROC", mode="lines+markers",
        line=dict(color=COLORS["blue"], width=2, dash="dot"),
        marker=dict(size=5),
    ), secondary_y=True)
    fig.update_layout(
        title="Missed Churners vs Model AUC per Batch",
        plot_bgcolor=COLORS["card"], paper_bgcolor=COLORS["card"],
        font=dict(color=COLORS["text"]),
        legend=dict(bgcolor=COLORS["card"]),
        margin=dict(l=60, r=60, t=40, b=40),
    )
    fig.update_yaxes(title_text="Missed churners", secondary_y=False)
    fig.update_yaxes(title_text="AUC-ROC", range=[0.5, 1.0], secondary_y=True)
    return fig


def build_roi_cumulative_chart(df: pd.DataFrame) -> go.Figure:
    """Cumulative annual loss projection across the monitoring window."""
    if df.empty or "roi_total_monthly_loss" not in df.columns:
        return go.Figure()

    cumulative = df["roi_total_monthly_loss"].cumsum()
    fig = go.Figure()
    fig.add_trace(go.Scatter(
        x=df["batch_id"], y=cumulative,
        fill="tozeroy", fillcolor="rgba(226,75,74,0.12)",
        line=dict(color="#E24B4A", width=2.5),
        name="Cumulative loss (₹)",
    ))
    fig.update_layout(
        title="Cumulative Estimated Loss Across All Batches (₹)",
        xaxis_title="Batch ID", yaxis_title="Cumulative Loss (₹)",
        plot_bgcolor=COLORS["card"], paper_bgcolor=COLORS["card"],
        font=dict(color=COLORS["text"]),
        margin=dict(l=60, r=40, t=40, b=40),
    )
    return fig


# ── Fleet Health Chart builder ────────────────────────────────────────────────

def build_fleet_status_chart(fleet_df: pd.DataFrame) -> go.Figure:
    """Horizontal bar showing latest AUC per model, coloured by health status."""
    if fleet_df.empty or "latest_auc" not in fleet_df.columns:
        return go.Figure()

    df = fleet_df.dropna(subset=["latest_auc"]).copy()
    if df.empty:
        return go.Figure()

    color_map = {
        "healthy":  COLORS["none"],
        "warning":  COLORS["amber"],
        "critical": COLORS["critical"],
        "inactive": COLORS["muted"],
        "unknown":  COLORS["muted"],
    }
    bar_colors = [color_map.get(s, COLORS["muted"]) for s in df.get("status", ["unknown"] * len(df))]

    fig = go.Figure(go.Bar(
        x=df["latest_auc"],
        y=df["name"],
        orientation="h",
        marker_color=bar_colors,
        text=[f"{v:.4f}" for v in df["latest_auc"]],
        textposition="outside",
        customdata=df[["version", "status", "n_batches"]].values,
        hovertemplate=(
            "<b>%{y}</b><br>"
            "AUC: %{x:.4f}<br>"
            "Version: %{customdata[0]}<br>"
            "Status: %{customdata[1]}<br>"
            "Batches logged: %{customdata[2]}<extra></extra>"
        ),
    ))
    fig.add_vline(x=0.80, line_dash="dash", line_color=COLORS["warning"],
                  annotation_text="Warning (0.80)", annotation_position="top right")
    fig.add_vline(x=0.70, line_dash="dash", line_color=COLORS["critical"],
                  annotation_text="Critical (0.70)", annotation_position="top right")
    fig.update_xaxes(range=[0.5, 1.05])
    fig.update_layout(
        title="Fleet — Latest AUC by Model",
        xaxis_title="AUC-ROC",
        plot_bgcolor=COLORS["card"], paper_bgcolor=COLORS["card"],
        font=dict(color=COLORS["text"]),
        margin=dict(l=160, r=80, t=40, b=40),
        height=max(200, len(df) * 70),
    )
    return fig


def build_fleet_roi_chart(fleet_df: pd.DataFrame) -> go.Figure:
    """Bar chart of estimated monthly ROI loss per model."""
    if fleet_df.empty or "roi_monthly_loss" not in fleet_df.columns:
        return go.Figure()

    df = fleet_df.dropna(subset=["roi_monthly_loss"]).copy()
    if df.empty:
        return go.Figure()

    fig = go.Figure(go.Bar(
        x=df["name"],
        y=df["roi_monthly_loss"],
        marker_color=[
            COLORS["critical"] if v > 50000 else
            COLORS["amber"]    if v > 10000 else
            COLORS["none"]
            for v in df["roi_monthly_loss"]
        ],
        text=[f"₹{v:,.0f}" for v in df["roi_monthly_loss"]],
        textposition="outside",
    ))
    fig.update_layout(
        title="Estimated Monthly Loss by Model (₹)",
        xaxis_title="Model", yaxis_title="Loss (₹)",
        plot_bgcolor=COLORS["card"], paper_bgcolor=COLORS["card"],
        font=dict(color=COLORS["text"]),
        margin=dict(l=60, r=60, t=40, b=60),
    )
    return fig


